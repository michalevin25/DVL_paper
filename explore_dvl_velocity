# Second derivative of velocity (jerk) per trajectory
for trajectory in range(1, 14):
    data = pd.read_csv(f"/Users/michal/Desktop/PhD/dvl paper/A-KIT-main/Data/Trajectory{trajectory}/DVL_trajectory{trajectory}.csv")
    time = data.iloc[:,0].values
    v_x  = data.iloc[:,1].values
    v_y  = data.iloc[:,2].values
    v_z  = data.iloc[:,3].values

    # second derivative using np.gradient twice (preserves signal length)
    d2vx = np.gradient(np.gradient(v_x, time), time)
    d2vy = np.gradient(np.gradient(v_y, time), time)
    d2vz = np.gradient(np.gradient(v_z, time), time)

    fig, axs = plt.subplots(3, 1, figsize=(10, 7), sharex=True)

    axs[0].plot(time, d2vx, color='forestgreen', linewidth=0.8)
    axs[0].set_ylabel("d²v_x/dt²")
    axs[0].grid()

    axs[1].plot(time, d2vy, color='cornflowerblue', linewidth=0.8)
    axs[1].set_ylabel("d²v_y/dt²")
    axs[1].grid()

    axs[2].plot(time, d2vz, color='darkorange', linewidth=0.8)
    axs[2].set_ylabel("d²v_z/dt²")
    axs[2].set_xlabel("Time (s)")
    axs[2].grid()

    fig.suptitle(f"Second Derivative of Velocity — Trajectory {trajectory}")
    plt.tight_layout()
    plt.show()

