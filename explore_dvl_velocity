################  Histogram of velociy ################ 

def histogram(velocity, name):

    plt.hist(velocity, bins=50)
    plt.title(f"{name} distribution traj {trajectory}")
    plt.xlabel("v_x [m/s]")
    plt.ylabel("count")
    plt.show()

    counts, bins = np.histogram(velocity, bins=50)

    peaks, _ = find_peaks(counts)

    # sort peaks by height
    top_peaks = peaks[np.argsort(counts[peaks])][-2:]

    # convert bin index -> velocity
    peak_velocities = (bins[top_peaks] + bins[top_peaks+1]) / 2
    

        
    return peak_velocities

