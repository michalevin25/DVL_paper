################ estimated trajectory ################ 
for trajectory in range (1,14):
    data = pd.read_csv(f"/Users/michal/Desktop/PhD/dvl paper/A-KIT-main/Data/Trajectory{trajectory}/DVL_trajectory{trajectory}.csv")
    time = data.iloc[:,0]
    v_x = data.iloc[:,1]
    v_y = data.iloc[:,2]
    v_z = data.iloc[:,3]

    # compute dt
    dt = np.diff(time, prepend=time[0])

    # integrate velocity -> position
    x = np.cumsum(v_x * dt)
    y = np.cumsum(v_y * dt)
    z = np.cumsum(v_z * dt)

    # 3D plot
    fig = plt.figure(figsize=(8,6))
    ax = fig.add_subplot(111, projection='3d')

    ax.plot(x, y, z, linewidth=1.5)

    ax.set_xlabel("X (m)")
    ax.set_ylabel("Y (m)")
    ax.set_zlabel("Z (m)")
    ax.set_title("Estimated 3D Trajectory from DVL Velocities")

