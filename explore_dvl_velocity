# 1D curvature map of velocity signals via UnivariateSpline
# κ(t) = |d²v/dt²| / (1 + (dv/dt)²)^(3/2)
from scipy.interpolate import UnivariateSpline

smoothing_factor = 0.5   # adjust: smaller = tighter fit
peak_height      = 0.1   # minimum combined curvature to count as a maneuver
peak_distance    = 10    # minimum samples between peaks

for trajectory in range(1, 14):
    data = pd.read_csv(f"/Users/michal/Desktop/PhD/dvl paper/A-KIT-main/Data/Trajectory{trajectory}/DVL_trajectory{trajectory}.csv")
    time = data.iloc[:,0].values
    v_x  = data.iloc[:,1].values
    v_y  = data.iloc[:,2].values
    v_z  = data.iloc[:,3].values

    curvatures = {}
    d2_store   = {}
    for label, signal in [("v_x", v_x), ("v_y", v_y), ("v_z", v_z)]:
        spl  = UnivariateSpline(time, signal, s=smoothing_factor)
        d1   = spl.derivative(n=1)(time)
        d2   = spl.derivative(n=2)(time)
